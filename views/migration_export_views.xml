<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================
         Configuración de Push (vista form — página completa, no diálogo)
         ============================ -->
    <record id="view_migration_push_config_form" model="ir.ui.view">
        <field name="name">migration.push.config.form</field>
        <field name="model">migration.push.config</field>
        <field name="arch" type="xml">
            <form string="Push de Migración v15 → v18">

                <sheet>
                    <group string="Conexión con el Receptor (Odoo 18)">
                        <group>
                            <field name="company_id"/>
                            <field name="batch_size"/>
                            <field name="inter_batch_pause"/>
                        </group>
                        <group>
                            <field name="target_url"
                                   placeholder="https://mi-odoo18.ejemplo.com"/>
                            <field name="target_api_key" password="True"/>
                        </group>
                    </group>

                    <!-- Test de conexión -->
                    <group>
                        <div>
                            <button name="action_test_connection"
                                    string="🔌 Probar Conexión"
                                    type="object"
                                    class="btn-secondary"/>
                        </div>
                        <field name="connection_status"
                               nolabel="1"
                               attrs="{'invisible': [('connection_status', '=', False)]}"
                               readonly="1"/>
                    </group>

                    <separator string="Modelos a Exportar"/>

                    <div class="mb8">
                        <button name="action_rebuild_list"
                                string="↺ Actualizar lista y conteos"
                                type="object"
                                class="btn-secondary btn-sm me-2"/>
                        <button name="action_select_all"
                                string="✔ Seleccionar todo"
                                type="object"
                                class="btn-secondary btn-sm me-2"/>
                        <button name="action_deselect_all"
                                string="✘ Deseleccionar todo"
                                type="object"
                                class="btn-secondary btn-sm"/>
                    </div>

                    <field name="model_line_ids" nolabel="1">
                        <tree editable="bottom">
                            <field name="selected" widget="boolean_toggle"/>
                            <field name="sequence" column_invisible="True"/>
                            <field name="model_name" readonly="1"/>
                            <field name="record_count" readonly="1"/>
                        </tree>
                    </field>

                    <!-- Resultado del último push -->
                    <group attrs="{'invisible': [('result_message', '=', False)]}">
                        <separator string="Resultado del último push"/>
                        <field name="result_message" nolabel="1"
                               widget="text" readonly="1"/>
                    </group>

                </sheet>

                <footer>
                    <button name="action_push_now"
                            string="🚀 Ejecutar Push"
                            type="object"
                            class="btn-primary"
                            confirm="¿Desea iniciar el push de los modelos seleccionados hacia el receptor v18?"/>
                </footer>

            </form>
        </field>
    </record>

    <!-- Acción que abre la configuración en página completa (no diálogo) -->
    <record id="action_migration_push_config" model="ir.actions.act_window">
        <field name="name">Push Manual de Migración</field>
        <field name="res_model">migration.push.config</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <!-- Abre siempre el singleton via contexto especial -->
        <field name="context">{'form_view_initial_mode': 'edit'}</field>
    </record>

    <!-- Server action para redirigir al singleton -->
    <record id="action_open_push_config" model="ir.actions.server">
        <field name="name">Abrir Configuración de Push</field>
        <field name="model_id" ref="model_migration_push_config"/>
        <field name="state">code</field>
        <field name="code">
action = env['migration.push.config'].get_or_create_singleton().get_formview_action()
        </field>
    </record>

    <!-- ============================
         Log de Exportación
         ============================ -->
    <record id="view_migration_export_log_tree" model="ir.ui.view">
        <field name="name">migration.export.log.list</field>
        <field name="model">migration.export.log</field>
        <field name="arch" type="xml">
            <tree string="Log de Exportación"
                  decoration-success="state == 'done'"
                  decoration-danger="state == 'error'"
                  decoration-info="state == 'running'">
                <field name="model_name"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'error'"
                       decoration-info="state == 'running'"/>
                <field name="records_exported"/>
                <field name="last_export_date"/>
                <field name="error_message" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="action_migration_export_log" model="ir.actions.act_window">
        <field name="name">Log de Exportación</field>
        <field name="res_model">migration.export.log</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ============================
         Menú bajo Ajustes → Migración
         ============================ -->
    <menuitem id="menu_migration_root_v15"
              name="Migración v15→v18"
              parent="base.menu_administration"
              sequence="99"
              groups="base.group_system"/>

    <menuitem id="menu_migration_push_manual"
              name="Push Manual a v18"
              parent="menu_migration_root_v15"
              action="action_open_push_config"
              sequence="10"/>

    <menuitem id="menu_migration_export_log"
              name="Log de Exportación"
              parent="menu_migration_root_v15"
              action="action_migration_export_log"
              sequence="20"/>
</odoo>
